<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#1a1d27"
    app:cardCornerRadius="12dp"
    app:strokeColor="#2a2d3a"
    app:strokeWidth="1dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Thumbnail -->
        <ImageView
            android:id="@+id/ivThumb"
            android:layout_width="96dp"
            android:layout_height="64dp"
            android:scaleType="centerCrop"
            android:background="#0f1117"
            android:contentDescription="thumbnail"/>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginHorizontal="12dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#e2e8f0"
                android:textSize="13sp"
                android:maxLines="2"
                android:ellipsize="end"/>

            <!-- Chips row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipQuality"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="480p"
                    android:textSize="11sp"
                    android:textColor="#00e5ff"
                    app:chipBackgroundColor="#0d2a2d"
                    app:chipStrokeColor="#00e5ff"
                    app:chipStrokeWidth="1dp"
                    android:checkable="false"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipType"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:layout_marginStart="6dp"
                    android:text="MP4"
                    android:textSize="11sp"
                    android:textColor="#f59e0b"
                    app:chipBackgroundColor="#1a1500"
                    app:chipStrokeColor="#f59e0b"
                    app:chipStrokeWidth="1dp"
                    android:checkable="false"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tvSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="11sp"
                android:textColor="#64748b"/>

        </LinearLayout>

        <!-- Download button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownload"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬇"
            android:textSize="18sp"
            android:textColor="#0f1117"
            app:backgroundTint="#22c55e"
            android:minWidth="0dp"
            android:paddingHorizontal="12dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
